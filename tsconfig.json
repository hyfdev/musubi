{
  "extends": "./.void/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "paths": {
      "#shared/*": ["./shared/*"],
      "void/routes": ["./.void/routes.d.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vite/client", "void/env"]
  },
  "include": ["app", "server", "shared"]
}