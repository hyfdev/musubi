{
  "name": "musubi",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "pnpm prepare:npm-skills && pnpm prepare:void-skills",
    "prepare:npm-skills": "skills-npm --yes --agents claude",
    "prepare:void-skills": "pnpm void init --agents",
    "dev": "VITE_USE_SNAPSHOT=1 vite dev",
    "dev:live": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check:build": "VITE_USE_SNAPSHOT=1 vite build",
    "check:types": "vue-tsc -b",
    "check:lint": "oxlint --type-aware",
    "check:format": "oxfmt --check",
    "fix:lint": "oxlint --type-aware --fix",
    "fix:format": "oxfmt",
    "snapshot:update": "node --experimental-strip-types scripts/snapshot-update.ts"
  },
