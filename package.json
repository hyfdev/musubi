{
  "name": "musubi",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run notion:setup && vp run check:build",
    "dev": "vp run brand:check && vp run font:build && vp run nuxt:dev",
    "font:build": "node scripts/font/build.ts",
    "font:setup": "node --env-file-if-exists=.env.local scripts/font/index.ts",
    "notion:setup": "node --env-file-if-exists=.env.local scripts/notion/index.ts",
    "preview": "vp run static:serve",
    "postinstall": "nuxt prepare",
    "prepare": "vp config",
    "nuxt:dev": "nuxt dev",
    "nuxt:typecheck": "nuxt typecheck",
    "nuxt:generate": "nuxt generate",
    "static:finalize": "node scripts/finalize-static-artifact.mjs",
    "static:serve": "node scripts/serve-static.mjs"
  },
  "dependencies": {
    "@notionhq/client": "5.23.2",
    "fonteditor-core": "2.6.3",
    "h3": "1.15.11",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "subset-font": "2.5.0",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@google/design.md": "^0.3.0",
    "@types/node": "^24.13.3",
    "@unocss/nuxt": "^66.7.5",
    "@unocss/preset-wind4": "^66.7.5",
    "nuxt": "^4.4.8",
    "shiki": "4.3.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "vite-plus": "0.2.5",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=24.11.0 <25"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
