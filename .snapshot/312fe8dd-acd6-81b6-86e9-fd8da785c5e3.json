n  on<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    existing.push(handler as EventHandler);\n    this.handlers.set(event, existing);\n  }\n\n  off<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    this.handlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  emit<K extends keyof Events>(event: K, payload: Events[K]): void {\n    const existing = this.handlers.get(event) ?? [];\n    for (const handler of existing) {\n      handler(payload);\n    }\n  }\n}","a|8E","a|8F","o|5v|8G|61","n|VCFyHKm","olswGZMaMxB0J5Tmj79paw,\"start\",\"end\"","a|8J","olswGZMaMxB0J5Tmj79paw","4xXsRhVOsW_T","a|8M|1h","n|CA","o|20|1w|8N|23|8O|8E","a|1y|8P|27","o|1u|8L|8Q|29","o|1q|8R|2B","o|8K|8S","o|1l|8J|8T","o|1i|8U","o|3C|O|3D|5t|8H|8I|8I|7|0|1f|1g|1h|8V","o|j|8W|2H","n|5","The magic is in ","a|8Z","K extends keyof Events","a|8b|7J",". This constrains each method to only accept keys from the event map, and ","a|8d","Events[K]","a|8f|7J"," resolves to the corresponding payload type.","a|8h","a|8a|8c|8e|8g|8i","o|1i|8j","n|VCFyHKn","8XEc1pK4V9zN_d4Bxb7zUg,\"start\",\"end\"","a|8m","8XEc1pK4V9zN_d4Bxb7zUg","Nl-IgKWdvgSy","a|8p|1h","n|G","o|20|1w|8q|23|8r|8Z","n|H","a|8p|8t","a|8p|8r","n|2g","a|8p|8w","o|7b|8u|7T","n|d","a|8p|8z","o|7b|90|7T","o|7Y|7X|8o|29|8x|8y|91|7I","a|92","o|7U|1w|8u|8v|84|8b|93","a|8p|55","n|1C","o|7U|1w|90|95|96|8d|2B","n|1p","a|8p|98","n|1o","a|8p|9A","n|2h","a|8p|9C","o|7b|99|7T","n|1y","a|8p|9F","o|7b|9G|7T","o|7Y|7X|8o|29|9D|9E|9H|7I","a|9I","o|7U|1w|99|9B|7d|8f|9J","n|1x","a|8p|9L","n|i","o|7U|1w|9G|9M|9N|8h|2B","a|1y|8s|94|97|9K|9O|27","o|1u|8o|9P|29","o|1q|9Q|2B","o|8n|9R","o|1l|8m|9S","o|1i|9T","o|3C|P|8Y|3E|8k|8l|8l|7|0|1f|1g|1h|9U","o|j|9V|2H","a|k|l|m|p|q|r|s|t|u|v|w","n|2","divider","n|VCFyHKp","irYT_PnMOBUAuGeiCZrvEg,\"start\",\"end\"","a|9b","irYT_PnM