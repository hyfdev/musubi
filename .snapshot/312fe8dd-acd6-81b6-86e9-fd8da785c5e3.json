(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    existing.push(handler as EventHandler);\n    this.handlers.set(event, existing);\n  }\n\n  off<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    this.handlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  emit<K extends keyof Events>(event: K, payload: Events[K]): void {\n    const existing = this.handlers.get(event) ?? [];\n    for (const handler of existing) {\n      handler(payload);\n    }\n  }\n}","a|8C","a|8D","o|5w|8E|1R","n|VCFyHKm","olswGZMaMxB0J5Tmj79paw,\"start\",\"end\"","a|8H","olswGZMaMxB0J5Tmj79paw","4xXsRhVOsW_T","a|8K|1h","n|CA","o|20|1w|8L|23|8M|8C","a|1y|8N|27","o|1u|8J|8O|29","o|1q|8P|2B","o|8I|8Q","o|1l|8H|8R","o|1i|8S","o|3C|O|3D|5u|8F|8G|8G|7|0|1f|1g|1h|8T","o|j|8U|2H","n|5","The magic is in ","a|8X","K extends keyof Events","a|8Z|7H",". This constrains each method to only accept keys from the event map, and ","a|8b","Events[K]","a|8d|7H"," resolves to the corresponding payload type.","a|8f","a|8Y|8a|8c|8e|8g","o|1i|8h","n|VCFyHKn","8XEc1pK4V9zN_d4Bxb7zUg,\"start\",\"end\"","a|8k","8XEc1pK4V9zN_d4Bxb7zUg","Nl-IgKWdvgSy","a|8n|1h","n|G","o|20|1w|8o|23|8p|8X","n|H","a|8n|8r","a|8n|8p","n|2g","a|8n|8u","o|7Z|8s|7R","n|d","a|8n|8x","o|7Z|8y|7R","o|7W|7V|8m|29|8v|8w|8z|7G","a|90","o|7S|1w|8s|8t|82|8Z|91","a|8n|56","n|1C","o|7S|1w|8y|93|94|8b|2B","n|1p","a|8n|96","n|1o","a|8n|98","n|2h","a|8n|9A","o|7Z|97|7R","n|1y","a|8n|9D","o|7Z|9E|7R","o|7W|7V|8m|29|9B|9C|9F|7G","a|9G","o|7S|1w|97|99|7b|8d|9H","n|1x","a|8n|9J","n|i","o|7S|1w|9E|9K|9L|8f|2B","a|1y|8q|92|95|9I|9M|27","o|1u|8m|9N|29","o|1q|9O|2B","o|8l|9P","o|1l|8k|9Q","o|1i|9R","o|3C|P|8W|3E|8i|8j|8j|7|0|1f|1g|1h|9S","o|j|9T|2H","a|k|l|m|p|q|r|s|t|u|v|w","n|2","divider","n|VCFyHKp","irYT_PnMOBUAuGeiCZrvEg,\"start\",\"end\"","a|9Z","irYT_PnMOBUAuGeiCZrvEg","o|1u|9b|31|2