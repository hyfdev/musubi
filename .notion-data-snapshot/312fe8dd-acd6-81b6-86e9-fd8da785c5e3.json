tMap> {\n  private handlers = new Map<keyof Events, EventHandler[]>();\n\n  on<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    existing.push(handler as EventHandler);\n    this.handlers.set(event, existing);\n  }\n\n  off<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    this.handlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  emit<K extends keyof Events>(event: K, payload: Events[K]): void {\n    const existing = this.handlers.get(event) ?? [];\n    for (const handler of existing) {\n      handler(payload);\n    }\n  }\n}","a|8H","a|8I","o|5y|8J|64","n|VCFyHKm","olswGZMaMxB0J5Tmj79paw,\"start\",\"end\"","a|8M","olswGZMaMxB0J5Tmj79paw","4xXsRhVOsW_T","a|8P|1i","n|CA","o|21|1x|8Q|24|8R|8H","a|1z|8S|28","o|1v|8O|8T|2A","o|1r|8U|2C","o|8N|8V","o|1m|8M|8W","o|1j|8X","o|3E|P|3F|5w|8K|8L|8L|7|0|1g|1h|1i|8Y","o|k|8Z|2I","n|5","The magic is in ","a|8c","K extends keyof Events","a|8e|7M",". This constrains each method to only accept keys from the event map, and ","a|8g","Events[K]","a|8i|7M"," resolves to the corresponding payload type.","a|8k","a|8d|8f|8h|8j|8l","o|1j|8m","n|VCFyHKn","8XEc1pK4V9zN_d4Bxb7zUg,\"start\",\"end\"","a|8p","8XEc1pK4V9zN_d4Bxb7zUg","Nl-IgKWdvgSy","a|8s|1i","n|G","o|21|1x|8t|24|8u|8c","n|H","a|8s|8w","a|8s|8u","n|2g","a|8s|8z","o|7e|8x|7W","n|d","a|8s|92","o|7e|93|7W","o|7b|7a|8r|2A|90|91|94|7L","a|95","o|7X|1x|8x|8y|87|8e|96","a|8s|58","n|1C","o|7X|1x|93|98|99|8g|2C","n|1p","a|8s|9B","n|1o","a|8s|9D","n|2h","a|8s|9F","o|7e|9C|7W","n|1y","a|8s|9I","o|7e|9J|7W","o|7b|7a|8r|2A|9G|9H|9K|7L","a|9L","o|7X|1x|9C|9E|7g|8i|9M","n|1x","a|8s|9O","n|i","o|7X|1x|9J|9P|9Q|8k|2C","a|1z|8v|97|9A|9N|9R|28","o|1v|8r|9S|2A","o|1r|9T|2C","o|8q|9U","o|1m|8p|9V","o|1j|9W","o|3E|Q|8b|3G|8n|8o|8o|7|0|1g|1h|1i|9X","o|k|9Y|2I","a|l|m|n|q|r|s|t|u|v|w|x","n|2","divider","n|VCFyHKp","irYT_PnMOBUAuGeiCZrvEg,\"start\",\"end\"","a|9e","irYT_PnMOBUAuGeiCZrvEg","o|1v|9g|33|2A","o|1r|9h|2C","o|9f|9i","o|1m|9e|9j","o|1j|9k","o|9a|R|9b|9c|9d|9d|7|0|1g|1h|1i|9l","o|k|9m|2I","Step 3: Adding Once and RemoveAll","a|9o","a|9p","o|1j|9q","Gmh294zX5cEEr6aUO0Ys-Q,\"start\",\"end\"","a|9s","Gmh294zX5cEEr6aUO0Ys-Q","piIGVORBbrCc","a|9v|1i","n|X","o|21|1x|9w|24|9x|9o","a|1z|9y|28","o|1v|9u|9z|2A","o|1r|A0|2C","o|9t|A1","o|1m|9s|A2","o|1j|A3","o|3v|S|3F|3w|9r|43|9d|9d|7|0|1g|1h|1i|A4","o|k|A5|2I","Let's extend with two more useful methods:","a|A7","a|A8","o|1j|A9","n|VCFyHKq","chJXBUZudFN0TqTgRxYKtA,\"start\",\"end\"","a|AC","chJXBUZudFN0TqTgRxYKtA","J2LY9u09-Tkj","a|AF|1i","o|21|1x|AG|24|4p|A7","a|1z|AH|28","o|1v|AE|AI|2A","o|1r|AJ|2C","o|AD|AK","o|1m|AC|AL","o|1j|AM","o|3E|T|3F|3G|AA|AB|AB|7|0|1g|1h|1i|AN","o|k|AO|2I","class TypedEmitter<Events extends EventMap> {\n  private handlers = new Map<keyof Events, EventHandler[]>();\n\n  on<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    existing.push(handler as EventHandler);\n    this.handlers.set(event, existing);\n  }\n\n  once<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const wrapper = ((payload: Events[K]) => {\n      handler(payload);\n      this.off(event, wrapper as EventHandler<Events[K]>);\n    }) as EventHandler;\n\n    const existing = this.handlers.get(event) ?? [];\n    existing.push(wrapper);\n    this.handlers.set(event, existing);\n  }\n\n  off<K extends keyof Events>(event: K, handler: EventHandler<Events[K]>): void {\n    const existing = this.handlers.get(event) ?? [];\n    this.handlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  removeAll<K extends keyof Events>(event?: K): void {\n    if (event) {\n      this.handlers.delete(event);\n    } else {\n      this.handlers.clear();\n    }\n  }\n\n  emit<K extends keyof Events>(event: K, payload: Events[K]): void {\n    const existing = this.handlers.get(event) ?? [];\n    for (const handler of existing) {\n      handler(payload);\n    }\n  }\n}","a|AQ","a|AR","o|5y|AS|64","n|VCFyHKr","l85-lFc2SCS2XsI3sFdYQA,\"start\",\"end\"","a|AV","l85-lFc2SCS2XsI3sFdYQA","BSPgbDG26Uv6","a|AY|1i","n|Kc","o|21|1x|AZ|24|Aa|AQ","a|1z|Ab|28","o|1v|AX|Ac|2A","o|1r|Ad|2C","o|AW|Ae","o|1m|AV|Af","o|1j|Ag","o|3E|U|3F|5w|AT|AU|AU|7|0|1g|1h|1i|Ah","o|k|Ai|2I","QyonNqpV53g3ULROiNMR9Q,\"start\",\"end\"","a|Ak","QyonNqpV53g3ULROiNMR9Q","o|1v|Am|33|2A","o|1r|An|2C","o|Al|Ao","o|1m|Ak|Ap","o|1j|Aq","o|9a|V|9b|9c|AU|AU|7|0|1g|1h|1i|Ar","o|k|As|2I","Step 4: Usage Examples","a|Au","a|Av","o|1j|Aw","n|VCFyHKs","XwB9AhziyhgrrNKdSlUkcA,\"start\",\"end\"","a|Az","XwB9AhziyhgrrNKdSlUkcA","sUJsGhh5LsdY","a|B2|1i","o|21|1x|B3|24|87|Au","a|1z|B4|28","o|1v|B1|B5|2A","o|1r|B6|2C","o|B0|B7","o|1m|Az|B8","o|1j|B9","o|3v|W|3F|3w|Ax|43|Ay|Ay|7|0|1g|1h|1i|BA","o|k|BB|2I","Define your events as an interface for better readability:","a|BD","a|BE","o|1j|BF","zNoNUB4UCNHgtHqvn3B62Q,\"start\",\"end\"","a|BH","zNoNUB4UCNHgtHqvn3B62Q","_gVUWOxPGsuj","a|BK|1i","n|w","o|21|1x|BL|24|BM|BD","a|1z|BN|28","o|1v|BJ|BO|2A","o|1r|BP|2C","o|BI|BQ","o|1m|BH|BR","o|1j|BS","o|3E|X|3F|3G|BG|Ay|Ay|7|0|1g|1h|1i|BT","o|k|BU|2I","interface AppEvents {\n  \"user:login\": { userId: string; role: \"admin\" | \"user\" };\n  \"user:logout\": { userId: string };\n  \"notification\": { message: string; type: \"info\" | \"error\" | \"success\" };\n  \"theme:change\": { theme: \"light\" | \"dark\" };\n}\n\nconst bus = new TypedEmitter<AppEvents>();\n\n// Fully typed — IDE autocompletes event names and payload fields\nbus.on(\"user:login\", (data) => {\n  console.log(`${data.userId} logged in as ${data.role}`);\n});\n\nbus.on(\"theme:change\", (data) => {\n  document.documentElement.dataset.theme = data.theme;\n});\n\n// Correct\nbus.emit(\"notification\", {\n  message: \"Welcome!\",\n  type: \"success\",\n});\n\n// Type